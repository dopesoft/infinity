# Core (Go service)
PORT=8080
DATABASE_URL=postgres://infinity:infinity@localhost:5432/infinity?sslmode=disable

# LLM provider selection: anthropic | openai | google
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929

# Provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Phase 2 tools
TAVILY_API_KEY=
HTTP_FETCH_ALLOWED_DOMAINS=*.github.com,*.anthropic.com,*.arxiv.org

# Cross-service URLs (Railway sets these on deploy)
CORE_URL=http://localhost:8080
STUDIO_URL=http://localhost:3000

# Auth (Supabase). Setting SUPABASE_URL is enough — JWKS URL + issuer
# are derived. Leave SUPABASE_URL empty to disable the auth gate (dev only).
SUPABASE_URL=https://hionigmbmkrahwfxaatf.supabase.co
# SUPABASE_JWKS_URL=
# SUPABASE_ISSUER=

# Studio (Next.js)
NEXT_PUBLIC_CORE_URL=http://localhost:8080
NEXT_PUBLIC_CORE_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_SUPABASE_URL=https://hionigmbmkrahwfxaatf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BUILD=dev
